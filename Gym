<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elite Fitness Club</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#0a0a0a;
color:white;
overflow-x:hidden;
}

header{
position:fixed;
top:0;
width:100%;
padding:25px 8%;
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(0,0,0,0.7);
backdrop-filter:blur(10px);
z-index:1000;
}

.logo{
font-size:32px;
font-weight:700;
color:#FFD700;
letter-spacing:2px;
}

nav a{
color:white;
text-decoration:none;
margin-left:30px;
transition:.3s;
}

nav a:hover{
color:#FFD700;
}

.hero{
height:100vh;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
background:
linear-gradient(rgba(0,0,0,.7),rgba(0,0,0,.7)),
url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1600&q=80');
background-size:cover;
background-position:center;
}

.hero-content h1{
font-size:80px;
margin-bottom:20px;
color:#FFD700;
}

.hero-content p{
font-size:22px;
margin-bottom:35px;
}

.btn{
padding:16px 40px;
background:#FFD700;
color:black;
font-weight:600;
text-decoration:none;
border-radius:50px;
transition:.3s;
}

.btn:hover{
transform:scale(1.08);
}

.section{
padding:100px 10%;
}

.section-title{
text-align:center;
font-size:45px;
margin-bottom:60px;
color:#FFD700;
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
}

.card{
background:#151515;
padding:35px;
border-radius:20px;
transition:.4s;
border:1px solid #222;
}

.card:hover{
transform:translateY(-10px);
border-color:#FFD700;
}

.card h3{
margin-bottom:15px;
color:#FFD700;
}

.pricing{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:30px;
}

.price-box{
background:#151515;
padding:40px;
width:320px;
border-radius:20px;
text-align:center;
border:2px solid #FFD700;
}

.price{
font-size:50px;
color:#FFD700;
margin:20px 0;
}

footer{
background:#000;
text-align:center;
padding:30px;
margin-top:50px;
}
</style>
</head>

<body>

<header>
<div class="logo">ELITE GYM</div>

<nav>
<a href="#">Home</a>
<a href="#">Programs</a>
<a href="#">Pricing</a>
<a href="#">Contact</a>
</nav>
</header>

<section class="hero">
<div class="hero-content">
<h1>ELITE FITNESS CLUB</h1>
<p>Luxury Training • World-Class Equipment • Premium Results</p>
<a href="#" class="btn">Become a Member</a>
</div>
</section
